NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL — used in email templates and API responses
NEXT_PUBLIC_APP_URL=https://lawnbowl.app

# Email sender address
EMAIL_FROM=Lawnbowling <noreply@lawnbowl.app>

# VAPID keys for push notifications (generate with web-push)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Monitoring webhook secret (used to authenticate incoming alert webhooks)
MONITORING_WEBHOOK_SECRET=
