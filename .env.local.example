# -----------------------------------------------------------------------------
# Core app + Supabase (required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://www.lawnbowl.app

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_WEBHOOK_SECRET=your-supabase-webhook-secret

# -----------------------------------------------------------------------------
# Stripe (required for paid subscriptions + shop checkout)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_MEMBERSHIP_WEBHOOK_SECRET=whsec_xxx

STRIPE_PREMIUM_PRICE_ID=price_xxx
STRIPE_VENUE_OWNER_PRICE_ID=price_xxx
STRIPE_MEMBERSHIP_MONTHLY_PRICE_ID=price_xxx
STRIPE_MEMBERSHIP_ANNUAL_PRICE_ID=price_xxx

# -----------------------------------------------------------------------------
# Printify (required for merch sync + fulfillment)
# NOTE: this codebase currently references BOTH PRINTIFY_API_TOKEN and
# PRINTIFY_API_KEY in different modules. Set both to the same value for now.
# -----------------------------------------------------------------------------
PRINTIFY_API_TOKEN=printify_pat_xxx
PRINTIFY_API_KEY=printify_pat_xxx
PRINTIFY_SHOP_ID=1234567
PRINTIFY_WEBHOOK_SECRET=printify_webhook_secret_xxx

# -----------------------------------------------------------------------------
# Email (required for transactional email)
# -----------------------------------------------------------------------------
EMAIL_API_KEY=re_xxx
EMAIL_FROM=Lawnbowling <noreply@lawnbowl.app>

# -----------------------------------------------------------------------------
# Push notifications (required for web push)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Cron + admin tooling
# -----------------------------------------------------------------------------
CRON_SECRET=your-cron-secret
ADMIN_EMAILS=admin@example.com,ops@example.com
ADMIN_SEED_SECRET=your-admin-seed-secret

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
PARTNER_REQUEST_TIMEOUT_MINUTES=5
ENABLE_SERWIST=0

# Sentry sourcemap upload during build (optional but recommended)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
