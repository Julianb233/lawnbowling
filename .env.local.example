# =============================================================================
# Lawnbowling Environment Variables
# Copy to .env.local and fill in your values
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App URL ---
NEXT_PUBLIC_APP_URL=https://lawnbowl.app

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_VENUE_OWNER_PRICE_ID=price_...

# --- Email (Resend / SendGrid / etc.) ---
EMAIL_API_KEY=re_...
EMAIL_FROM=Lawnbowling <noreply@lawnbowl.app>

# --- Push Notifications (VAPID) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# --- Printify (Print-on-Demand Shop) ---
PRINTIFY_API_KEY=your-printify-api-token
PRINTIFY_SHOP_ID=your-printify-shop-id
PRINTIFY_WEBHOOK_SECRET=your-printify-webhook-secret

# --- Cron Jobs ---
CRON_SECRET=your-cron-secret

# --- SEO Verification ---
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code
NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-code

# --- Partner Requests ---
PARTNER_REQUEST_TIMEOUT_MINUTES=5
